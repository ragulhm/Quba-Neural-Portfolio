{
  "name": "django-portfolio",
  "version": "1.0.0",
  "description": "Tailwind CLI integration for Django",
  "private": true,
  "scripts": {
    "tailwind:build": "npx tailwindcss -i ./static/css/input.css -o ./static/css/output.css --minify",
    "tailwind:watch": "npx tailwindcss -i ./static/css/input.css -o ./static/css/output.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7"
  }
}
